---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 1200px;
				margin: auto;
				padding: 2rem 1rem;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
				gap: 3rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			.blog-card {
				height: 100%;
				display: flex;
				flex-direction: column;
				background: var(--card-bg);
				border-radius: 24px;
				border: 1px solid var(--card-border);
				overflow: hidden;
				box-shadow: 0 4px 15px var(--card-shadow);
				transition: all 0.3s ease;
			}
			.blog-card:hover {
				transform: translateY(-8px);
				box-shadow: 0 15px 35px var(--card-shadow);
				border-color: var(--accent);
			}
			.image-link {
				width: 100%;
				height: 240px;
				overflow: hidden;
			}
			.blog-card img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.5s ease;
			}
			.blog-card:hover img {
				transform: scale(1.05);
			}
			.content {
				flex: 1;
				padding: 2rem;
			}
			.meta-tags {
				display: flex;
				gap: 10px;
				align-items: center;
				margin-bottom: 1rem;
			}
			.read-tag {
				font-family: 'Roboto Mono', monospace;
				font-size: 0.75rem;
				font-weight: 700;
				color: var(--gray-med);
				background: var(--gray-light);
				padding: 0.25rem 0.75rem;
				border-radius: 100px;
			}
			.title {
				font-size: 1.5rem;
				margin: 0.5rem 0 1rem 0;
				color: var(--text-color);
				text-decoration: none;
				display: block;
				font-family: 'Roboto Mono', monospace;
				font-weight: 700;
				line-height: 1.3;
			}
			.description {
				font-size: 0.95rem;
				color: var(--text-muted);
				line-height: 1.6;
				text-align: justify;
			}
			@media (max-width: 768px) {
				ul { grid-template-columns: 1fr; }
				.content { padding: 1.5rem; }
				.title { font-size: 1.3rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<ul>
				{
					posts.map((post) => (
						<li>
							<div class="blog-card">
								<a href={`/blog/${post.id}/`} class="image-link">
									<img src={typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage?.src} alt="" />
								</a>
								<div class="content">
									<div class="meta-tags">
										<span class="badge">{post.data.category}</span>
										<span class="read-tag">⏱️ 3 MIN</span>
									</div>
									<p style="font-size: 0.85rem; color: var(--gray-med); margin-bottom: 0.5rem;">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<a href={`/blog/${post.id}/`} class="title">
										{post.data.title}
									</a>
									<p class="description">{post.data.description}</p>
								</div>
							</div>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>