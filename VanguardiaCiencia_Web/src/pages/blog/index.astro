---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort((a, b) => {
	const dateA = new Date(a.data.pubDate).valueOf();
	const dateB = new Date(b.data.pubDate).valueOf();
	if (dateB !== dateA) return dateB - dateA;
	return b.id.localeCompare(a.id);
});

const featuredPost = posts[0];
const otherPosts = posts.slice(1);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 1400px;
				margin: 0 auto;
				padding: 2rem 1.5rem;
				box-sizing: border-box;
				overflow-x: hidden;
			}
			.featured-section {
				display: grid;
				grid-template-columns: 1.2fr 0.8fr;
				gap: 3rem;
				background: var(--section-bg);
				padding: 3rem;
				border-radius: 32px;
				margin-bottom: 5rem;
				border: 1px solid var(--card-border);
				box-shadow: 0 10px 30px var(--card-shadow);
				align-items: center;
				width: 100%;
				box-sizing: border-box;
			}
			.featured-image img {
				width: 100%;
				height: 500px;
				object-fit: cover;
				border-radius: 20px;
				box-shadow: 0 20px 40px var(--card-shadow);
				display: block;
			}
			.featured-content h1 {
				font-size: 3rem;
				margin: 1rem 0 1.5rem 0;
				line-height: 1.2;
				text-align: left;
				word-break: break-word;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
				gap: 2.5rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
				width: 100%;
				justify-content: center;
			}
			.post-card-item {
				width: 100%;
				display: flex;
				justify-content: center;
			}
			.blog-card {
				width: 100%;
				max-width: 450px;
				background: var(--card-bg);
				border-radius: 28px;
				border: 1px solid var(--card-border);
				overflow: hidden;
				box-shadow: 0 4px 15px var(--card-shadow);
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				display: flex;
				flex-direction: column;
				box-sizing: border-box;
			}
			.blog-card:hover {
				transform: translateY(-10px);
				box-shadow: 0 20px 40px var(--card-shadow);
				border-color: var(--accent);
			}
			.image-link {
				width: 100%;
				height: 240px;
				overflow: hidden;
			}
			.blog-card img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.6s ease;
			}
			.content {
				padding: 1.5rem;
				flex: 1;
			}
			.title {
				font-size: 1.5rem;
				margin: 0.5rem 0 1rem 0;
				color: var(--text-color);
				text-decoration: none;
				display: block;
				font-family: 'Roboto Mono', monospace;
				font-weight: 700;
				line-height: 1.3;
				word-break: break-word;
			}
			.description {
				font-size: 0.95rem;
				color: var(--text-muted);
				line-height: 1.6;
				text-align: justify;
				hyphens: none;
			}

			@media (max-width: 1000px) {
				main {
					padding: 1.5rem 1rem;
				}
				.featured-section { 
					grid-template-columns: 1fr; 
					padding: 2rem 1.2rem; 
					text-align: center;
					margin-bottom: 3rem;
					margin-left: -10px; /* Ajuste solicitado -10px */
					width: calc(100% + 20px);
				}
				.featured-image img { 
					height: auto;
					max-height: 350px; 
					margin: 0 auto;
				}
				.featured-content h1 { 
					font-size: 2.2rem; 
					text-align: center;
				}
				.featured-content .meta-tags {
					justify-content: center;
				}
				.featured-content .description {
					text-align: center;
				}
				ul {
					grid-template-columns: 1fr;
					gap: 2rem;
					margin-left: -10px; /* Ajuste solicitado -10px */
					width: calc(100% + 20px);
				}
				.blog-card {
					max-width: 100%;
					margin: 0 auto;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{featuredPost && (
				<section class="featured-section" id="featured-item">
					<div class="featured-image">
						<img src={typeof featuredPost.data.heroImage === 'string' ? featuredPost.data.heroImage : featuredPost.data.heroImage?.src} alt="" />
					</div>
					<div class="featured-content">
						<div class="meta-tags">
							<span class="badge">{featuredPost.data.category}</span>
							<span class="read-tag">ÚLTIMA NOTICIA</span>
						</div>
						<p style="font-size: 0.9rem; color: var(--gray-med); margin-bottom: 0.5rem;">
							<FormattedDate date={featuredPost.data.pubDate} />
						</p>
						<a href={`/blog/${featuredPost.id}/`} class="title" style="font-size: 2.5rem;">
							{featuredPost.data.title}
						</a>
						<p class="description" style="font-size: 1.1rem; margin-bottom: 2rem;">{featuredPost.data.description}</p>
						<a href={`/blog/${featuredPost.id}/`} class="btn-primary">Leer investigación completa</a>
					</div>
				</section>
			)}

			<ul id="posts-grid">
				{
					otherPosts.map((post) => (
						<li class="post-card-item" data-category={post.data.category}>
							<div class="blog-card">
								<a href={`/blog/${post.id}/`} class="image-link">
									<img src={typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage?.src} alt="" />
								</a>
								<div class="content">
									<div class="meta-tags">
										<span class="badge">{post.data.category}</span>
										<span class="read-tag">⏱️ 3 MIN</span>
									</div>
									<p style="font-size: 0.85rem; color: var(--gray-med); margin-bottom: 0.5rem;">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<a href={`/blog/${post.id}/`} class="title">
										{post.data.title}
									</a>
									<p class="description">{post.data.description}</p>
								</div>
							</div>
						</li>
					))
				}
			</ul>
		</main>

		<script is:inline>
			const urlParams = new URLSearchParams(window.location.search);
			const categoryFilter = urlParams.get('category');
			
			if (categoryFilter) {
				const featured = document.getElementById('featured-item');
				const gridItems = document.querySelectorAll('.post-card-item');
				
				if (featured) {
					const badge = featured.querySelector('.badge');
					if (badge && badge.textContent.trim() !== categoryFilter) {
						featured.style.display = 'none';
					} else {
						const tag = featured.querySelector('.read-tag');
						if (tag) tag.textContent = `DESTACADO EN ${categoryFilter.toUpperCase()}`;
					}
				}

				gridItems.forEach(item => {
					if (item.getAttribute('data-category') === categoryFilter) {
						item.style.display = 'flex';
					} else {
						item.style.display = 'none';
					}
				});
			}
		</script>
		<Footer />
	</body>
</html>