---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import AdBanner from '../components/AdBanner.astro';

const posts = (await getCollection('blog')).sort((a, b) => {
	const dateA = new Date(a.data.pubDate).valueOf();
	const dateB = new Date(b.data.pubDate).valueOf();
	
	if (dateB !== dateA) {
		return dateB - dateA;
	}
	
	return b.id.localeCompare(a.id);
});

// Forzar que la noticia más reciente sea la portada
const featuredPost = posts[0];
const recentPosts = posts.slice(1);

// Helper para obtener la URL de la imagen de forma segura
const getImageUrl = (heroImage) => {
	if (!heroImage) return '/blog-placeholder-about.jpg';
	return typeof heroImage === 'string' ? heroImage : heroImage.src;
};

// Helper para clases de categorías (quita tildes y pone guiones)
const categoryClass = (cat) => {
	return cat.toLowerCase()
		.replace(/\s+/g, '-')
		.normalize("NFD")
		.replace(/[\u0300-\u036f]/g, "");
};
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 1400px;
				margin: 0 auto;
				padding: 2rem 1.5rem;
				box-sizing: border-box;
				overflow-x: hidden; /* Seguridad extra */
			}
			.hero-section {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 3rem;
				align-items: center;
				margin-bottom: 5rem;
				padding: 3rem;
				background: var(--section-bg);
				border-radius: 32px;
				border: 1px solid var(--card-border);
				box-shadow: 0 10px 30px var(--card-shadow);
				width: 100%;
				box-sizing: border-box;
			}
			.hero-content h1 {
				font-size: 3.5rem;
				margin: 0 0 1.5rem 0;
				line-height: 1.1;
				word-break: break-word; /* Evita que el texto empuje la caja */
			}
			.hero-image img {
				width: 100%;
				max-width: 100%;
				aspect-ratio: 16 / 9; /* Proporción áurea moderna */
				object-fit: cover;
				border-radius: 20px;
				box-shadow: 0 20px 40px var(--card-shadow);
				display: block;
			}
			.recent-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
				gap: 2.5rem;
				width: 100%;
				justify-content: center;
			}
			.recent-card {
				text-decoration: none;
				color: inherit;
				transition: all 0.3s ease;
				background: var(--card-bg);
				padding: 1.5rem;
				border-radius: 24px;
				border: 1px solid var(--card-border);
				box-shadow: 0 4px 15px var(--card-shadow);
				display: flex;
				flex-direction: column;
				width: 100%;
				box-sizing: border-box;
			}
			.recent-card img {
				width: 100%;
				aspect-ratio: 16 / 9; /* Uniformidad total */
				object-fit: cover;
				border-radius: 16px;
				margin-bottom: 1.5rem;
			}

			@media (max-width: 900px) {
				main {
					padding: 1.5rem 1rem;
				}
				.hero-section {
					grid-template-columns: 1fr;
					padding: 2rem 1.2rem;
					gap: 2.5rem;
					text-align: center;
					margin-bottom: 3rem;
					margin-left: -2px; /* Ajuste milimétrico izquierda */
					width: calc(100% + 4px);
				}
				.hero-content h1 {
					font-size: 2.2rem;
					text-align: center;
				}
				.hero-image img {
					aspect-ratio: 16 / 9; /* Mantiene la estética en móvil */
				}
				.recent-grid {
					grid-template-columns: 1fr;
					padding: 0;
					gap: 2rem;
					margin-left: -2px; /* Ajuste milimétrico izquierda */
					width: calc(100% + 4px);
				}
				.recent-card {
					max-width: 100%;
					margin: 0 auto;
				}
				.recent-card img {
					aspect-ratio: 16 / 9;
				}
			}
		</style>
	</head>
	<body>
		<Header title={SITE_TITLE} />
		<main>
			<section class="hero-section">
				<div class="hero-content">
					<span class="section-title">En Portada</span>
					<div class="meta-tags">
						<span class={`badge ${categoryClass(featuredPost.data.category)}`}>{featuredPost.data.category}</span>
						<span class="read-tag">⏱️ 3 MIN</span>
					</div>
					<h1>{featuredPost.data.title}</h1>
					<p style="margin-bottom: 2rem; color: var(--text-muted);">{featuredPost.data.description}</p>
					<a href={`/blog/${featuredPost.id}/`} class="btn-primary">
						Leer investigación completa →
					</a>
				</div>
				<div class="hero-image">
					<img src={getImageUrl(featuredPost.data.heroImage)} alt={featuredPost.data.title} />
				</div>
			</section>

			<AdBanner slot="home-middle" />

			<section>
				<span class="section-title">Vanguardia 2026</span>
				<div class="recent-grid">
					{recentPosts.map((post) => (
						<a href={`/blog/${post.id}/`} class="recent-card">
							<img src={getImageUrl(post.data.heroImage)} alt={post.data.title} />
							<div class="meta-row">
								<span class={`badge ${categoryClass(post.data.category)}`}>{post.data.category}</span>
								<span class="read-tag-small">⏱️ 3 MIN</span>
							</div>
							<p style="font-size: 0.85rem; color: var(--gray-med); margin-bottom: 0.5rem;"><FormattedDate date={post.data.pubDate} /></p>
							<h3>{post.data.title}</h3>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
