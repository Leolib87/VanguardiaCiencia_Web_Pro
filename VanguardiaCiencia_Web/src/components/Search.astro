---
import { getCollection } from 'astro:content';
const allPosts = await getCollection('blog');
const searchData = allPosts.map(post => ({
	title: post.data.title,
	url: `/blog/${post.id}/`,
	description: post.data.description
}));
---
<div class="search-container">
	<button id="search-btn" aria-label="Buscar noticias">
		<span class="material-symbols-outlined">search</span>
	</button>
	
	<div id="search-modal" class="search-modal">
		<div class="modal-content">
			<div class="modal-header">
				<input type="text" id="search-input" placeholder="Buscar temas (IA, ADN, Luna...)" autocomplete="off" />
				<button id="close-search">&times;</button>
			</div>
			<div id="search-results" class="search-results"></div>
		</div>
	</div>
</div>

<script is:inline define:vars={{ searchData }}>
	document.addEventListener('DOMContentLoaded', () => {
		const btn = document.getElementById('search-btn');
		const modal = document.getElementById('search-modal');
		const close = document.getElementById('close-search');
		const input = document.getElementById('search-input');
		const results = document.getElementById('search-results');

		btn.onclick = () => {
			modal.style.display = 'block';
			input.focus();
		};
		close.onclick = () => modal.style.display = 'none';
		window.onclick = (e) => { if(e.target == modal) modal.style.display = 'none'; };

		input.oninput = (e) => {
			const query = e.target.value.toLowerCase();
			results.innerHTML = '';
			if (query.length < 2) return;

			const filtered = searchData.filter(post => 
				post.title.toLowerCase().includes(query) || 
				post.description.toLowerCase().includes(query)
			);

			filtered.forEach(post => {
				const div = document.createElement('div');
				div.className = 'result-item';
				div.innerHTML = `<a href="${post.url}"><h4>${post.title}</h4><p>${post.description.substring(0, 80)}...</p></a>`;
				results.appendChild(div);
			});
		};
	});
</script>

<style>
	#search-btn {
		background: none;
		border: none;
		cursor: pointer;
		color: var(--text-color);
		display: flex;
		align-items: center;
		padding: 0.5rem;
		opacity: 0.8;
	}
	.search-modal {
		display: none;
		position: fixed;
		z-index: 100000;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		background-color: rgba(0,0,0,0.8);
		backdrop-filter: blur(5px);
	}
	.modal-content {
		background-color: var(--card-bg);
		margin: 5% auto;
		padding: 2rem;
		border-radius: 20px;
		width: 90%;
		max-width: 700px;
		box-shadow: 0 25px 50px rgba(0,0,0,0.5);
	}
	.modal-header {
		display: flex;
		gap: 1rem;
		margin-bottom: 2rem;
	}
	#search-input {
		flex: 1;
		padding: 1rem;
		border-radius: 12px;
		border: 1px solid var(--border-color);
		background: var(--bg-color);
		color: var(--text-color);
		font-size: 1.2rem;
	}
	#close-search {
		background: none;
		border: none;
		color: var(--text-color);
		font-size: 2rem;
		cursor: pointer;
	}
	.result-item {
		padding: 1rem 0;
		border-bottom: 1px solid var(--border-color);
	}
	.result-item a { text-decoration: none; color: inherit; }
	.result-item h4 { margin: 0 0 0.5rem 0; font-size: 1.1rem; color: var(--accent); }
	.result-item p { margin: 0; font-size: 0.9rem; color: var(--gray-med); }
</style>
