---
interface Props {
	title: string;
	author: string;
	image: string;
	link: string;
	description: string;
}

const { title, author, image, link, description } = Astro.props;
---
<div class="amazon-box">
	<div class="amazon-label">Lectura Recomendada por la Redacción</div>
	<div class="amazon-flex">
		<img src={image} alt={title} />
		<div class="amazon-info">
			<h4>{title}</h4>
			<span class="author">por {author}</span>
			<p>{description}</p>
			<a href={link} target="_blank" class="amazon-btn">Ver en Amazon →</a>
		</div>
	</div>
</div>

<style>
	.amazon-box {
		border: 2px solid #eee;
		border-radius: 16px;
		padding: 1.5rem;
		margin: 3rem 0;
		background: #fff;
		position: relative;
	}
	.amazon-label {
		position: absolute;
		top: -12px;
		left: 20px;
		background: #ff9900;
		color: white;
		padding: 2px 12px;
		font-size: 0.7rem;
		font-weight: 800;
		border-radius: 4px;
		text-transform: uppercase;
		font-family: 'Roboto Mono', monospace;
	}
	.amazon-flex {
		display: flex;
		gap: 1.5rem;
		align-items: center;
	}
	.amazon-flex img {
		width: 100px;
		height: auto;
		box-shadow: 0 5px 15px rgba(0,0,0,0.1);
		border-radius: 4px;
	}
	.amazon-info h4 {
		margin: 0 0 0.2rem 0;
		font-size: 1.2rem;
	}
	.amazon-info .author {
		font-size: 0.85rem;
		color: #666;
		display: block;
		margin-bottom: 0.8rem;
	}
	.amazon-info p {
		font-size: 0.9rem;
		margin-bottom: 1rem;
		line-height: 1.4;
	}
	.amazon-btn {
		display: inline-block;
		background: #232f3e;
		color: white !important;
		padding: 0.6rem 1.2rem;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 700;
		font-size: 0.85rem;
		transition: background 0.2s;
	}
	.amazon-btn:hover {
		background: #37475a;
	}
	@media (max-width: 600px) {
		.amazon-flex { flex-direction: column; text-align: center; }
	}
</style>
