---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import Search from './Search.astro';
---

<header>
	<nav>
		<div class="logo">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/blog">Ciencia</HeaderLink>
			<HeaderLink href="/blog?category=Salud">Salud</HeaderLink>
			<HeaderLink href="/blog?category=Tecnologia">Tecnología</HeaderLink>
			<HeaderLink href="/blog?category=Ambiente">Ambiente</HeaderLink>
			<HeaderLink href="/about">Acerca de</HeaderLink>
			<div class="nav-actions" style="display: flex; gap: 0.5rem; align-items: center;">
				<Search />
				<ThemeToggle />
			</div>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0;
		background: var(--header-bg);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border-color);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	
	nav {
		max-width: 1020px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 1.5rem;
		height: 70px;
	}

	.logo a {
		font-family: 'Roboto Mono', monospace;
		font-weight: 700;
		font-size: 1.2rem;
		text-decoration: none;
		color: var(--text-color);
		letter-spacing: -0.02em;
	}

	.internal-links {
		display: flex;
		gap: 1rem;
	}

	.internal-links a {
		font-family: 'Roboto Mono', monospace;
		font-size: 0.9rem;
		font-weight: 500;
		text-transform: uppercase;
		text-decoration: none;
		color: var(--gray-med);
		padding: 0.5rem 0.8rem;
		border-radius: 6px;
		transition: all 0.2s ease;
	}

	.internal-links a:hover {
		color: var(--accent);
		background: var(--gray-light);
	}

	.internal-links a.active {
		color: var(--accent);
		border-bottom: none;
	}

	@media (max-width: 600px) {
		.internal-links {
			gap: 0.5rem;
		}
		.logo a {
			font-size: 1rem;
		}
		.internal-links a {
			font-size: 0.8rem;
			padding: 0.4rem;
		}
	}
</style>
