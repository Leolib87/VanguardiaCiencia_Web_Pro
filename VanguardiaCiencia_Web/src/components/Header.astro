---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import Search from './Search.astro';
---

<header>
	<nav>
		<div class="logo">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<div class="nav-wrapper">
			<div class="internal-links">
				<HeaderLink href="/">Inicio</HeaderLink>
				<HeaderLink href="/blog">Ciencia</HeaderLink>
				<HeaderLink href="/blog?category=Salud">Salud</HeaderLink>
				<HeaderLink href="/blog?category=Tecnologia">Tecnología</HeaderLink>
				<HeaderLink href="/blog?category=Ambiente">Ambiente</HeaderLink>
				<HeaderLink href="/about">Acerca de</HeaderLink>
			</div>
			<div class="nav-actions">
				<Search />
				<ThemeToggle />
			</div>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0;
		background: var(--header-bg);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border-color);
		position: sticky;
		top: 0;
		z-index: 1000;
	}
	
	nav {
		max-width: 1440px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 2rem;
		height: 80px;
	}

	.logo a {
		font-family: 'Roboto Mono', monospace;
		font-weight: 700;
		font-size: 1.4rem;
		text-decoration: none;
		color: var(--text-color);
		letter-spacing: -0.02em;
		white-space: nowrap;
	}

	.nav-wrapper {
		display: flex;
		align-items: center;
		gap: 2rem;
		flex: 1;
		justify-content: flex-end;
	}

	.internal-links {
		display: flex;
		gap: 0.5rem;
	}

	.internal-links a {
		font-family: 'Roboto Mono', monospace;
		font-size: 0.85rem;
		font-weight: 600;
		text-transform: uppercase;
		text-decoration: none;
		color: var(--gray-med);
		padding: 0.6rem 1rem;
		border-radius: 8px;
		transition: all 0.2s ease;
	}

	.internal-links a:hover, .internal-links a.active {
		color: var(--accent);
		background: var(--accent-light);
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding-left: 1rem;
		border-left: 1px solid var(--border-color);
	}

	@media (max-width: 1100px) {
		nav {
			flex-direction: column;
			height: auto;
			padding: 1rem;
		}
		.nav-wrapper {
			width: 100%;
			flex-direction: column;
			gap: 1rem;
			align-items: center;
		}
		.internal-links {
			width: 100%;
			overflow-x: auto;
			padding-bottom: 0.5rem;
			justify-content: flex-start;
			scrollbar-width: none;
		}
		.internal-links::-webkit-scrollbar { display: none; }
		.nav-actions {
			border-left: none;
			border-top: 1px solid var(--border-color);
			width: 100%;
			justify-content: center;
			padding: 0.5rem 0 0 0;
		}
	}
</style>
