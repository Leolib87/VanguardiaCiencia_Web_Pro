---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import AdBanner from '../components/AdBanner.astro';
import NewsletterBox from '../components/NewsletterBox.astro';
import ShareButtons from '../components/ShareButtons.astro';
import CitationBox from '../components/CitationBox.astro';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
const currentUrl = Astro.url.toString();

// Obtener 3 artículos relacionados aleatorios (excluyendo el actual)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
	.filter((post) => post.data.title !== title)
	.sort(() => Math.random() - 0.5)
	.slice(0, 3);
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" is:inline set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "NewsArticle",
			"headline": title,
			"description": description,
			"image": [heroImage?.src || heroImage],
			"datePublished": pubDate,
			"dateModified": updatedDate || pubDate,
			"author": [{
				"@type": "Organization",
				"name": "Vanguardia Ciencia Editorial",
				"url": "https://vanguardiaciencia.com/about"
			}],
			"publisher": {
				"@type": "Organization",
				"name": "Vanguardia Ciencia",
				"logo": {
					"@type": "ImageObject",
					"url": "https://vanguardiaciencia.com/favicon.svg"
				}
			}
		})} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding-top: 1rem;
			}
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				max-height: 450px;
				object-fit: cover;
			}
			.prose {
				width: 920px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
				text-align: justify;
				text-justify: inter-word;
				hyphens: none;
			}
			.verified-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				background: #e6f9ed;
				color: #1a7f37;
				padding: 0.4rem 1rem;
				border-radius: 100px;
				font-size: 0.75rem;
				font-weight: 700;
				text-transform: uppercase;
				margin-bottom: 1.5rem;
				font-family: 'Roboto Mono', monospace;
				border: 1px solid #dafbe1;
			}
			.verified-badge .material-symbols-outlined {
				font-size: 1rem;
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--gray-med);
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 1rem;
			}
			.last-updated-on {
				font-style: italic;
			}
			.reading-time {
				font-family: 'Roboto Mono', monospace;
				font-size: 0.85rem;
				color: #0070f3;
				background: #e6f2ff;
				padding: 2px 8px;
				border-radius: 4px;
				font-weight: 600;
			}
			.related-section {
				margin-top: 4rem;
				padding-top: 2rem;
				border-top: 2px solid #eee;
			}
			.related-section h3 {
				font-family: 'Roboto Mono', monospace;
				font-size: 1.2rem;
				margin-bottom: 2rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.related-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
				gap: 1.5rem;
				margin-bottom: 2rem;
			}
			.related-card {
				text-decoration: none;
				color: inherit;
				transition: transform 0.2s;
			}
			.related-card:hover {
				transform: translateY(-5px);
			}
			.related-card img {
				width: 100%;
				height: 120px;
				object-fit: cover;
				border-radius: 8px;
				margin-bottom: 0.8rem;
			}
			.related-card h4 {
				font-size: 0.95rem;
				line-height: 1.4;
				margin: 0;
			}
		</style>
	</head>

	<body>
		<div id="global-progress-bar"></div>
		<Header />
		<ShareButtons />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt={title} />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="verified-badge">
							<span class="material-symbols-outlined">verified</span>
							Fuente Verificada: Nature / Science Index
						</div>
						<div class="date">
							<FormattedDate date={pubDate} />
							<span class="reading-time">⏱️ 3 min de lectura</span>
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<AdBanner slot="blog-top" />
					<slot />
					
					<NewsletterBox />

					<CitationBox title={title} pubDate={pubDate} url={currentUrl} />

					<div class="related-section">
						<h3>Sigue Explorando la Vanguardia</h3>
						<div class="related-grid">
							{relatedPosts.map((post) => (
								<a href={`/blog/${post.id}/`} class="related-card">
									<img src={typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage?.src} alt="" />
									<div class="related-meta" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
										<span class="badge" style="margin-bottom: 0; font-size: 0.6rem; padding: 0.1rem 0.5rem;">{post.data.category}</span>
										<span style="font-family: 'Roboto Mono', monospace; font-size: 0.65rem; color: #888;">⏱️ 3 MIN</span>
									</div>
									<h4>{post.data.title}</h4>
								</a>
							))}
						</div>
					</div>

					<AdBanner slot="blog-bottom" />
				</div>
			</article>
		</main>
		<div class="sticky-footer-ad">
			<AdBanner slot="mobile-sticky" format="horizontal" />
		</div>
		<Footer />
	</body>
</html>

<style is:global>
	.sticky-footer-ad {
		position: fixed;
		bottom: 0;
		left: 0;
		width: 100%;
		background: var(--header-bg);
		backdrop-filter: blur(10px);
		border-top: 1px solid var(--border-color);
		z-index: 1000;
		display: flex;
		justify-content: center;
		padding: 5px 0;
		box-shadow: 0 -5px 15px rgba(0, 0, 0, 0.2);
	}
	/* Optimizamos el banner interno para que encaje en la barra */
	.sticky-footer-ad :global(.ad-container) {
		margin: 0 !important;
		border: none !important;
		background: transparent !important;
		height: 60px !important;
	}
</style>
